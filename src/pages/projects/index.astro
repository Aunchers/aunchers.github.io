---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
---

<BaseLayout title="Projects - CHAIRS" description="things I've built, broken, and occasionally fixed." ogType="website">
  <nav class="sub-nav">
    <a href="/">home</a>
    <span class="sub-nav-sep">/</span>
    <span>projects</span>
  </nav>

  <h1 class="page-title"><em>/</em>projects</h1>

  <div class="projects-grid">
    {projects.map((proj) => (
      <a href={`/projects/${proj.data.name.toLowerCase()}`} class="project-card-minimal">
        <span class="project-name">{proj.data.name}</span>
        <span class="project-desc">{proj.data.description}</span>
        {proj.data.tech && proj.data.tech.length > 0 && (
          <div class="project-tech-minimal">
            {proj.data.tech.slice(0, 3).map(t => <span class="tech-dot">{t}</span>)}
            {proj.data.tech.length > 3 && <span class="tech-dot">+{proj.data.tech.length - 3}</span>}
          </div>
        )}
      </a>
    ))}
  </div>

  <div class="flex-between" style="font-size:13px; margin-top: 2rem;">
    <span class="muted-text">{projects.length} projects</span>
    <a href="https://github.com/aunchers">github</a>
  </div>
</BaseLayout>
