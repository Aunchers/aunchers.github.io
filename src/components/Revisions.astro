---
interface Props {
  path: string;
}
const { path } = Astro.props;
---

<span class="rev-wrap" data-path={path}>
  <button class="rev-btn">[diff]</button>
  <div class="rev-panel">
    <div class="rev-h">
      <span>revisions</span>
      <button class="rev-x">x</button>
    </div>
    <div class="rev-l"></div>
  </div>
</span>

<script define:vars={{ path }}>
document.querySelectorAll('.rev-wrap').forEach(function(w) {
  var btn = w.querySelector('.rev-btn');
  var panel = w.querySelector('.rev-panel');
  var pclose = w.querySelector('.rev-x');
  var list = w.querySelector('.rev-l');

  btn.onclick = function() { panel.classList.toggle('open'); if (panel.classList.contains('open') && !panel.dataset.p) { list.innerHTML = '<div class="rev-lo">loading...</div>'; fetch('https://api.github.com/repos/aunchers/aunchers.github.io/commits?path=src/content/posts/' + path + '.mdx&per_page=10').then(function(r) { return r.json(); }).then(function(cs) { list.innerHTML = '<ul>' + cs.map(function(x) { return '<li><a href="' + x.html_url + '" target="_blank"><span>' + new Date(x.commit.author.date).toLocaleDateString() + '</span> ' + x.commit.message.split('\n')[0] + '</a></li>'; }).join('') + '</ul>'; panel.dataset.p = 'y'; }).catch(function() { list.innerHTML = '<div class="rev-le">failed</div>'; }); } };
  pclose.onclick = function() { panel.classList.remove('open'); };
});
</script>

<style>
.rev-wrap { display: inline; }
.rev-btn { font-size: 11px; color: var(--muted); background: none; border: none; cursor: pointer; padding: 0; }
.rev-btn:hover { color: var(--accent); }

.rev-panel {
  position: fixed;
  bottom: 3rem;
  right: 1rem;
  width: 220px;
  max-height: 250px;
  background: var(--bg);
  border: 1px dashed var(--muted);
  display: none;
  z-index: 999;
}
.rev-panel.open { display: block; }

.rev-h {
  display: flex;
  justify-content: space-between;
  padding: 0.35rem;
  border-bottom: 1px solid rgba(85,85,85,0.3);
  font-size: 10px;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 700;
}
.rev-x { background: none; border: none; color: var(--muted); cursor: pointer; }

.rev-l { max-height: 200px; overflow-y: auto; padding: 0.25rem; }
.rev-l ul { list-style: none; margin: 0; padding: 0; }
.rev-l li { padding: 0.35rem; font-size: 10px; border-bottom: 1px solid rgba(85,85,85,0.15); }
.rev-l a { color: var(--text); text-decoration: none; display: block; }
.rev-l a:hover { color: var(--accent); }
.rev-l span { color: var(--accent); display: block; margin-bottom: 0.15rem; }
.rev-lo, .rev-le { color: var(--muted); font-size: 10px; padding: 0.5rem; }
</style>