---
interface Props {
  code: string;
}
const { code } = Astro.props;

const lines = code.split('\n').map(line => {
  if (line.startsWith('+') && !line.startsWith('+++')) {
    return { type: 'add', content: line.slice(1) };
  } else if (line.startsWith('-') && !line.startsWith('---')) {
    return { type: 'remove', content: line.slice(1) };
  } else if (line.startsWith('@@')) {
    return { type: 'header', content: line };
  } else if (line.startsWith('+++') || line.startsWith('---') || line.startsWith('diff') || line.startsWith('index')) {
    return { type: 'meta', content: line };
  } else {
    return { type: 'context', content: line };
  }
}).filter(line => line.type !== 'meta');
---

<div class="diff-container">
  <pre class="diff-content">{lines.map(line => (
    <span class={`diff-${line.type}`}>{line.type === 'add' ? '+' : line.type === 'remove' ? '-' : ' '}{line.content}</span>
  ))}</pre>
</div>

<style>
  .diff-container {
    border: 1px dashed var(--muted);
    margin: 1.5rem 0;
    font-family: 'Fira Code', monospace;
    font-size: 12px;
    overflow-x: auto;
  }
  .diff-content {
    margin: 0;
    padding: 0.75rem;
    background: transparent;
    border: none;
  }
  .diff-content span { display: block; }
  .diff-add {
    background: rgba(74, 222, 128, 0.1);
    color: var(--text);
  }
  .diff-remove {
    background: rgba(248, 113, 113, 0.1);
    color: var(--text);
  }
  .diff-header {
    color: var(--accent);
    font-weight: 700;
  }
  .diff-context {
    color: var(--muted);
  }

  [data-theme="paper"] .diff-add {
    background: rgba(74, 222, 128, 0.12);
  }
  [data-theme="paper"] .diff-remove {
    background: rgba(248, 113, 113, 0.12);
  }

  [data-theme="midnight"] .diff-add {
    background: rgba(74, 222, 128, 0.06);
  }
  [data-theme="midnight"] .diff-remove {
    background: rgba(248, 113, 113, 0.06);
  }
</style>